{
  "name": "pi-ai-tools",
  "version": "1.0.0",
  "description": "AI task runner — executes predefined function chains on cron schedules",
  "main": "dist/index.js",
  "bin": {
    "pi-ai-tools": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "ts-node src/index.ts",
