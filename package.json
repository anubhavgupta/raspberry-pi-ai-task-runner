    "@ai-sdk/openai-compatible": "^2.0.51",
    "ai": "^6.0.209",
    "jsdom": "^29.1.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.0"
  }
}
