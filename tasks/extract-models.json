{
  "name": "extract-models",
  "description": "Fetch Hugging Face models page, extract list via AI, save to disk",
  "cron": "0 4 * * 0",
  "env": {
    "MODEL_URL": "https://huggingface.co/models",
    "LLM_API_URL": "http://192.168.1.33:7838/v1/chat/completions",
    "LLM_MODEL": "default",
    "TELEGRAM_CHAT_ID": "6383504811",
    "OUTPUT_DIR": "C:\\projects\\pi-ai-tools\\output"
  },
  "functions": [
    {
      "id": "fetch-page",
      "type": "shell",
      "command": "node",
      "args": ["functions/fetch-page.js", "--url", "$MODEL_URL"],
      "saveResultToVariable": "RAW_HTML"
    },
    {
      "id": "save-content",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/models-content.txt", "--content", "{{$RAW_HTML}}"]
    },
    {
      "id": "ai-extract",
      "type": "shell",
      "command": "node",
      "args": ["functions/ai-task.js", "--instructions-file", "tasks/extract-models-instructions.txt", "--content-file", "output/models-content.txt"]
    },
    {
      "id": "save",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/models.txt", "--content", "{{result}}"]
    },
    {
      "id": "notify-telegram",
      "type": "shell",
      "command": "node",
      "args": ["functions/send-telegram.js", "--chat-id", "$TELEGRAM_CHAT_ID", "--file", "$OUTPUT_DIR/models.txt"]
    }
  ]
}
