{
  "name": "huggingface-models-digest",
  "description": "Fetch Hugging Face models page, extract top models, send digest to Telegram",
  "cron": "0 6 * * *",
  "env": {
    "MODEL_URL": "https://huggingface.co/models",
    "LLM_API_URL": "http://192.168.1.33:7838/v1/chat/completions",
    "LLM_MODEL": "default",
    "TELEGRAM_CHAT_ID": "6383504811",
    "OUTPUT_DIR": "C:\\projects\\pi-ai-tools\\output"
  },
  "functions": [
    {
      "id": "fetch-page",
      "type": "shell",
      "command": "node",
      "args": ["functions/fetch-page.js", "--url", "$MODEL_URL"],
      "saveResultToVariable": "RAW_HTML"
    },
    {
      "id": "save-digest",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "models-digest.txt", "--content", "{{$RAW_HTML}}"]
    },
    {
      "id": "notify-telegram",
      "type": "shell",
      "command": "node",
      "args": ["functions/send-telegram.js", "--chat-id", "$TELEGRAM_CHAT_ID", "--file", "output/models-digest.txt"]
    }
  ]
}
