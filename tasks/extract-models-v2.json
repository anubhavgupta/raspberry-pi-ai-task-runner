{
  "name": "extract-models-v2",
  "description": "Fetch Hugging Face models, compare with stored list, send new models to Telegram",
  "cron": "38 22 * * *",
  "env": {
    "MODEL_URL": "https://huggingface.co/models",
    "LLM_API_URL": "http://192.168.1.33:7838/v1/chat/completions",
    "LLM_MODEL": "default",
    "TELEGRAM_CHAT_ID": "6383504811",
    "OUTPUT_DIR": "C:\\projects\\pi-ai-tools\\output"
  },
  "functions": [
    {
      "id": "fetch-page",
      "type": "shell",
      "command": "node",
      "args": ["functions/fetch-page.js", "--url", "$MODEL_URL"],
      "saveResultToVariable": "RAW_HTML"
    },
    {
      "id": "save-content",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/models-raw-content.txt", "--content", "{{$RAW_HTML}}"]
    },
    {
      "id": "ai-extract",
      "type": "shell",
      "command": "node",
      "args": ["functions/ai-task.js", "--instructions-file", "tasks/extract-models-instructions.txt", "--content-file", "output/models-raw-content.txt"],
      "saveResultToVariable": "CURRENT_MODELS"
    },
    {
      "id": "save-current",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/models.txt", "--content", "{{$CURRENT_MODELS}}"]
    },
    {
      "id": "read-old",
      "type": "shell",
      "command": "node",
      "args": ["functions/read-from-disk.js", "--file", "output/models-old.txt"]
    },
    {
      "id": "save-compare-content",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/compare-content.txt", "--content", "Previous models:\n{{result}}\n\nCurrent models:\n{{$CURRENT_MODELS}}"]
    },
    {
      "id": "compare",
      "type": "shell",
      "command": "node",
      "args": ["functions/ai-task.js", "--instructions-file", "tasks/compare-models-instructions.txt", "--content-file", "output/compare-content.txt"],
      "saveResultToVariable": "COMPARISON"
    },
    {
      "id": "save-comparison",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/comparison.txt", "--content", "{{$COMPARISON}}"]
    },
    {
      "id": "backup-current",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/models-old.txt", "--content", "{{$CURRENT_MODELS}}"]
    },
    {
      "id": "notify-telegram",
      "type": "shell",
      "command": "node",
      "args": ["functions/send-telegram.js", "--chat-id", "$TELEGRAM_CHAT_ID", "--file", "$OUTPUT_DIR/comparison.txt"]
    }
  ]
}
