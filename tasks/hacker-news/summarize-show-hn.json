{
  "name": "summarize-show-hn",
  "description": "Read show-hn.txt, categorize and summarize what people are building, send digest to Telegram",
  "cron": "0 16 * * *",
  "env": {
    "TELEGRAM_CHAT_ID": "6383504811",
    "LLM_API_URL": "http://192.168.1.33:7838/v1/chat/completions",
    "LLM_MODEL": "default"
  },
  "functions": [
    {
      "id": "read-show-hn",
      "type": "shell",
      "command": "node",
      "args": ["functions/read-from-disk.js", "--file", "output/show-hn.txt"]
    },
    {
      "id": "ai-summarize",
      "type": "shell",
      "command": "node",
      "args": ["functions/ai-task.js", "--instructions-file", "tasks/hacker-news/summarize-show-hn-instructions.txt", "--content-file", "output/show-hn.txt"],
      "saveResultToVariable": "SUMMARY"
    },
    {
      "id": "save-summary",
      "type": "shell",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/show-hn-summary.txt", "--content", "{{$SUMMARY}}"]
    },
    {
      "id": "notify-telegram",
      "type": "shell",
      "command": "node",
      "args": ["functions/send-telegram.js", "--chat-id", "$TELEGRAM_CHAT_ID", "--file", "output/show-hn-summary.txt"]
    },
    {
      "id": "clear-show-hn",
      "type": "terminal",
      "command": "node",
      "args": ["functions/save-to-disk.js", "--file", "output/show-hn.txt", "--content", ""]
    }
  ]
}
